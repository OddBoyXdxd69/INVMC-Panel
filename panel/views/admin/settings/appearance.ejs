<%- include('../../components/admin_template') %>

<main class="relative">
  <!-- Enhanced Header -->
  <div class="px-6 pt-6 pb-4 border-b border-neutral-800 bg-gradient-to-r from-neutral-900 to-neutral-800">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <%= req.translations.settings %>
        </h1>
        <p class="mt-1 text-sm text-neutral-400">Change appearance and social settings for INVMC.</p>
      </div>
    </div>
  </div>

  <%- include('../../components/settings') %>

  <div class="px-6 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Panel Branding Card -->
      <div class="bg-neutral-900 rounded-xl border border-neutral-800 overflow-hidden shadow-lg">
        <div class="px-5 py-4 border-b border-neutral-800 bg-neutral-800/50">
          <h2 class="text-lg font-semibold text-white">Panel Branding</h2>
        </div>
        <div class="p-5 space-y-6">
          <form action="/admin/settings/change/name" method="POST" class="space-y-2">
            <label class="block text-sm font-medium text-neutral-300">Panel Name</label>
            <div class="flex gap-2">
              <input name="name" type="text" value="<%= name %>" class="flex-1 bg-neutral-800 border border-neutral-700 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
              <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">Save</button>
            </div>
          </form>

          <form action="/admin/settings/change/logo-url" method="POST" class="space-y-2">
            <label class="block text-sm font-medium text-neutral-300">Logo URL</label>
            <div class="flex gap-2">
              <input name="logoUrl" type="text" value="<%= settings.logoUrl || '' %>" placeholder="https://example.com/logo.png" class="flex-1 bg-neutral-800 border border-neutral-700 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
              <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">Update</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Social Links Card -->
      <div class="bg-neutral-900 rounded-xl border border-neutral-800 overflow-hidden shadow-lg">
        <div class="px-5 py-4 border-b border-neutral-800 bg-neutral-800/50">
          <h2 class="text-lg font-semibold text-white">Social & Support Links</h2>
        </div>
        <div class="p-5">
          <form action="/admin/settings/social" method="POST" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-neutral-300">GitHub Repository URL</label>
              <input name="github" type="text" value="<%= settings.github || 'https://github.com/OddBoyXdxd69/INVMC-Panel' %>" class="w-full mt-1 bg-neutral-800 border border-neutral-700 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-neutral-300">Discord Invite URL</label>
              <input name="discord" type="text" value="<%= settings.discord || 'https://discord.gg/invmc' %>" class="w-full mt-1 bg-neutral-800 border border-neutral-700 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-neutral-300">Support/Donation URL</label>
              <input name="support" type="text" value="<%= settings.support || '' %>" class="w-full mt-1 bg-neutral-800 border border-neutral-700 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2 rounded-lg text-sm font-semibold transition">Save All Links</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>
<%- include('../../components/footer') %>
