<%- include('../components/template') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<%
function formatLastUpdated(dateString) {
  const date = new Date(dateString);
  const now = new Date();
  const diffTime = Math.abs(now - date);
  const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
  if (diffDays > 30) {
    return date.toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  } else {
    return `${diffDays} day${diffDays !== 1 ? 's' : ''} ago`;
  }
}

function getFileIcon(purpose) {
  if (purpose === 'folder') return '<i class="fas fa-folder text-indigo-400"></i>';
  const icons = {
    programming: '<i class="fas fa-file-code text-blue-400"></i>',
    webDevelopment: '<i class="fas fa-file-code text-green-400"></i>',
    textDocument: '<i class="fas fa-file-alt text-gray-400"></i>',
    archive: '<i class="fas fa-file-archive text-orange-400"></i>',
    image: '<i class="fas fa-file-image text-pink-400"></i>',
    other: '<i class="fas fa-file text-neutral-500"></i>'
  };
  return icons[purpose] || icons.other;
}
%>

<style>
    .file-row {
        transition: all 0.2s ease;
        border-bottom: 1px solid rgba(255, 255, 255, 0.02);
    }
    .file-row:hover {
        background: rgba(255, 255, 255, 0.03);
        transform: scale(1.002);
    }
    .breadcrumb-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.85rem;
    }
    .floating-actions {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.75rem 1.5rem;
        border-radius: 9999px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        display: flex;
        gap: 1.5rem;
        z-index: 100;
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .floating-actions.active {
        opacity: 1;
        pointer-events: auto;
        bottom: 3rem;
    }
</style>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 opacity-0" id="main-content">
    <%- include('../components/instance') %>

    <!-- File Explorer Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <div class="flex items-center gap-3 overflow-x-auto scrollbar-hide w-full md:w-auto">
            <a href="./files" class="breadcrumb-item hover:text-white transition">
                <i class="fas fa-home"></i> /app/data
            </a>
            <% if (req.query.path) { %>
                <% const parts = req.query.path.split('/'); let currentPath = ''; %>
                <% parts.forEach((part, index) => { if (part) { currentPath += encodeURIComponent(part); %>
                    <span class="text-gray-700">/</span>
                    <a href="./files?path=<%= currentPath %>" class="breadcrumb-item hover:text-white transition">
                        <%= part %>
                    </a>
                <% currentPath += '/'; } }) %>
            <% } %>
        </div>

        <div class="flex gap-2 w-full md:w-auto">
            <div class="relative flex-1 md:w-64">
                <input type="text" id="searchInput" placeholder="Search..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
            </div>
            <button onclick="document.getElementById('fileInput').click()" class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-xl text-sm font-bold transition flex items-center gap-2">
                <i class="fas fa-upload"></i> <span class="hidden sm:inline">Upload</span>
            </button>
            <input type="file" id="fileInput" multiple class="hidden">
        </div>
    </div>

    <!-- File Table -->
    <div class="glass-card overflow-hidden">
        <div class="overflow-x-auto w-full"><table class="w-full text-left border-collapse" style="table-layout: fixed;">
            <thead>
                <tr class="bg-white/5 text-[10px] font-bold text-gray-500 uppercase tracking-widest">
                    <th class="px-6 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded bg-gray-800 border-gray-700 text-indigo-600 focus:ring-indigo-500"></th>
                    <th class="px-6 py-4">Name</th>
                    <th class="px-6 py-4 w-32 hidden md:table-cell">Size</th>
                    <th class="px-6 py-4 w-40 hidden lg:table-cell">Modified</th>
                    <th class="px-6 py-4 w-20"></th>
                </tr>
            </thead>
            <tbody id="fileList">
                <% files.forEach(function(file) { %>
                    <tr class="file-row group cursor-pointer" onclick="handleFileClick(event, '<%= file.name %>', <%= file.isDirectory %>)">
                        <td class="px-6 py-4" onclick="event.stopPropagation()">
                            <input type="checkbox" class="file-checkbox rounded bg-gray-800 border-gray-700 text-indigo-600 focus:ring-indigo-500" data-name="<%= file.name %>">
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap overflow-hidden text-ellipsis">
                            <div class="flex items-center gap-3">
                                <span class="text-xl flex-shrink-0"><%- getFileIcon(file.purpose || (file.isDirectory ? 'folder' : 'other')) %></span>
                                <span class="text-sm font-medium text-gray-300 group-hover:text-white transition"><%= file.name %></span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-xs text-gray-500 hidden md:table-cell"><%= file.size %></td>
                        <td class="px-6 py-4 text-xs text-gray-500 hidden lg:table-cell"><%= formatLastUpdated(file.lastUpdated) %></td>
                        <td class="px-6 py-4 text-right" onclick="event.stopPropagation()">
                            <button class="text-gray-600 hover:text-white transition p-2"><i class="fas fa-ellipsis-v"></i></button>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table></div>
    </div>

    <!-- Floating Action Bar -->
    <div id="floatingActions" class="floating-actions">
        <span class="text-xs font-bold text-indigo-400 uppercase tracking-widest border-r border-white/10 pr-4 flex items-center">
            <span id="selectedCount">0</span> Selected
        </span>
        <button onclick="massAction('delete')" class="text-rose-400 hover:text-rose-300 transition text-sm font-bold flex items-center gap-2">
            <i class="fas fa-trash"></i> Delete
        </button>
        <button onclick="massAction('archive')" class="text-amber-400 hover:text-amber-300 transition text-sm font-bold flex items-center gap-2">
            <i class="fas fa-file-archive"></i> Archive
        </button>
    </div>
</main>

<script>
    gsap.to("#main-content", { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" });
    gsap.from(".file-row", { opacity: 0, x: -10, duration: 0.4, stagger: 0.05, delay: 0.2 });

    function handleFileClick(e, name, isDir) {
        if (isDir) {
            const currentPath = new URLSearchParams(window.location.search).get('path') || '';
            const newPath = currentPath ? `${currentPath}/${name}` : name;
            window.location.href = `./files?path=${newPath}`;
        } else {
            // Edit file logic
            window.location.href = `./files/edit/${name}${window.location.search}`;
        }
    }

    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.file-checkbox');
    const floatingBar = document.getElementById('floatingActions');
    const countDisplay = document.getElementById('selectedCount');

    function updateFloatingBar() {
        const checked = document.querySelectorAll('.file-checkbox:checked').length;
        countDisplay.textContent = checked;
        if (checked > 0) floatingBar.classList.add('active');
        else floatingBar.classList.remove('active');
    }

    selectAll.addEventListener('change', (e) => {
        checkboxes.forEach(cb => cb.checked = e.target.checked);
        updateFloatingBar();
    });

    checkboxes.forEach(cb => {
        cb.addEventListener('change', updateFloatingBar);
    });
</script>
<%- include('../components/footer') %>
