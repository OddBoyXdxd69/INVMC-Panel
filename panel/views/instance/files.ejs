<%- include('../components/template') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.0/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<%
function getFileIcon(purpose) {
  if (purpose === 'folder') return '<i class="fas fa-folder text-indigo-400"></i>';
  const icons = {
    programming: '<i class="fas fa-file-code text-blue-400"></i>',
    webDevelopment: '<i class="fas fa-file-code text-green-400"></i>',
    textDocument: '<i class="fas fa-file-alt text-gray-400"></i>',
    archive: '<i class="fas fa-file-archive text-orange-400"></i>',
    image: '<i class="fas fa-file-image text-pink-400"></i>',
    other: '<i class="fas fa-file text-neutral-500"></i>'
  };
  return icons[purpose] || icons.other;
}
%>

<style>
    .file-row {
        transition: all 0.2s ease;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(255, 255, 255, 0.02);
    }
    .file-row:hover {
        background: rgba(255, 255, 255, 0.05);
        transform: scale(1.005);
    }
    .breadcrumb-bar {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 0.75rem;
    }
    .modal-overlay {
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(4px);
    }
    .floating-actions {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(15, 23, 42, 0.9);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.75rem 1.5rem;
        border-radius: 9999px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        display: flex;
        gap: 1.5rem;
        z-index: 100;
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .floating-actions.active {
        opacity: 1;
        pointer-events: auto;
        bottom: 3rem;
    }
    .btn-action {
        padding: 0.6rem 1rem;
        border-radius: 0.75rem;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
</style>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 opacity-0" id="main-content">
    <%- include('../components/instance') %>

    <!-- Manager Toolbar -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 mb-6">
        <div class="breadcrumb-bar flex-1 px-4 py-3 flex items-center gap-2 overflow-x-auto scrollbar-hide w-full lg:w-auto">
            <a href="./files" class="text-indigo-400 hover:text-white transition whitespace-nowrap"><i class="fas fa-home mr-1"></i> root</a>
            <% if (req.query.path) { %>
                <% const parts = req.query.path.split('/'); let currentPath = ''; %>
                <% parts.forEach((part, index) => { if (part) { currentPath += part; %>
                    <span class="text-gray-700">/</span>
                    <a href="./files?path=<%= currentPath %>" class="text-gray-300 hover:text-white transition whitespace-nowrap"><%= part %></a>
                <% currentPath += '/'; } }) %>
            <% } %>
        </div>

        <div class="flex flex-wrap gap-2 w-full lg:w-auto">
            <button onclick="openModal('file')" class="btn-action bg-white/5 hover:bg-white/10 text-white border border-white/10">
                <i class="fas fa-file-plus text-indigo-400"></i> New File
            </button>
            <button onclick="openModal('folder')" class="btn-action bg-white/5 hover:bg-white/10 text-white border border-white/10">
                <i class="fas fa-folder-plus text-indigo-400"></i> New Folder
            </button>
            <button onclick="openModal('wget')" class="btn-action bg-indigo-600 hover:bg-indigo-500 text-white shadow-lg shadow-indigo-600/20">
                <i class="fas fa-cloud-download"></i> Remote Upload
            </button>
            <button onclick="document.getElementById('fileInput').click()" class="btn-action bg-emerald-600 hover:bg-emerald-500 text-white shadow-lg shadow-emerald-600/20">
                <i class="fas fa-upload"></i> Upload
            </button>
            <input type="file" id="fileInput" multiple class="hidden">
        </div>
    </div>

    <!-- Files Table -->
    <div class="glass-card overflow-hidden">
        <div class="overflow-x-auto w-full"><table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-black/20 text-[10px] font-bold text-gray-500 uppercase tracking-widest">
                    <th class="px-6 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded bg-gray-800 border-gray-700 text-indigo-600 focus:ring-indigo-500"></th>
                    <th class="px-6 py-4">Name</th>
                    <th class="px-6 py-4 w-32 hidden md:table-cell">Size</th>
                    <th class="px-6 py-4 w-40 hidden lg:table-cell">Last Modified</th>
                    <th class="px-6 py-4 w-20"></th>
                </tr>
            </thead>
            <tbody id="fileList">
                <% if (files.length === 0) { %>
                    <tr><td colspan="5" class="px-6 py-20 text-center text-gray-500 italic">This directory is empty.</td></tr>
                <% } %>
                <% files.forEach(function(file) { %>
                    <tr class="file-row group cursor-pointer" onclick="handleFileClick(event, '<%= file.name %>', <%= file.isDirectory %>)">
                        <td class="px-6 py-4" onclick="event.stopPropagation()">
                            <input type="checkbox" class="file-checkbox rounded bg-gray-800 border-gray-700 text-indigo-600 focus:ring-indigo-500" data-name="<%= file.name %>">
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                                <span class="text-2xl flex-shrink-0"><%- getFileIcon(file.isDirectory ? 'folder' : 'other') %></span>
                                <div class="min-w-0">
                                    <p class="text-sm font-bold text-white group-hover:text-indigo-400 transition truncate"><%= file.name %></p>
                                    <p class="text-[10px] text-gray-500 uppercase font-mono md:hidden"><%= file.size %></p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-xs font-mono text-gray-400 hidden md:table-cell"><%= file.size %></td>
                        <td class="px-6 py-4 text-xs text-gray-500 hidden lg:table-cell"><%= new Date(file.lastUpdated).toLocaleString() %></td>
                        <td class="px-6 py-4 text-right" onclick="event.stopPropagation()">
                            <button onclick="deleteSingle('<%= file.name %>')" class="text-gray-600 hover:text-rose-500 transition p-2"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table></div>
    </div>

    <!-- Floating Action Bar -->
    <div id="floatingActions" class="floating-actions">
        <span class="text-xs font-bold text-indigo-400 uppercase tracking-widest border-r border-white/10 pr-4 flex items-center">
            <span id="selectedCount">0</span> Items
        </span>
        <button onclick="massAction('delete')" class="text-rose-400 hover:text-rose-300 transition text-sm font-bold flex items-center gap-2">
            <i class="fas fa-trash"></i> Delete
        </button>
        <button onclick="massAction('archive')" class="text-amber-400 hover:text-amber-300 transition text-sm font-bold flex items-center gap-2">
            <i class="fas fa-file-archive"></i> Archive
        </button>
    </div>
</main>

<!-- Unified Modal -->
<div id="manager-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4">
    <div class="absolute inset-0 modal-overlay" onclick="closeModal()"></div>
    <div class="relative glass-card bg-neutral-900 max-w-md w-full p-8 shadow-2xl scale-95 transition-all duration-300" id="modal-content">
        <h3 class="text-xl font-bold text-white mb-2" id="modal-title">New Item</h3>
        <p class="text-xs text-gray-500 mb-6" id="modal-desc">Enter the details below.</p>
        
        <div class="space-y-4">
            <input type="text" id="modal-input" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition" placeholder="Enter name...">
            <div id="wget-extra" class="hidden">
                <p class="text-[10px] text-gray-500 italic">The file will be downloaded using wget directly into the current directory.</p>
            </div>
        </div>

        <div class="flex justify-end gap-3 mt-8">
            <button onclick="closeModal()" class="text-gray-400 hover:text-white transition font-bold text-xs uppercase tracking-widest">Cancel</button>
            <button id="modal-confirm" class="bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-3 rounded-xl text-sm font-bold transition shadow-lg shadow-indigo-600/20">Confirm</button>
        </div>
    </div>
</div>

<script>
    gsap.to("#main-content", { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" });
    gsap.from(".file-row", { opacity: 0, x: -10, duration: 0.4, stagger: 0.03, delay: 0.2 });

    const currentPath = new URLSearchParams(window.location.search).get('path') || '';

    function handleFileClick(e, name, isDir) {
        if (isDir) {
            const nextPath = currentPath ? `${currentPath}/${name}` : name;
            window.location.href = `./files?path=${encodeURIComponent(nextPath)}`;
        } else {
            window.location.href = `./files/edit/${name}${window.location.search}`;
        }
    }

    function openModal(type) {
        const modal = document.getElementById('manager-modal');
        const content = document.getElementById('modal-content');
        const title = document.getElementById('modal-title');
        const desc = document.getElementById('modal-desc');
        const input = document.getElementById('modal-input');
        const confirmBtn = document.getElementById('modal-confirm');
        const wgetExtra = document.getElementById('wget-extra');

        wgetExtra.classList.add('hidden');
        input.value = '';

        if (type === 'file') {
            title.textContent = 'Create New File';
            desc.textContent = 'Create a blank file in the current directory.';
            input.placeholder = 'e.g. server.properties';
            confirmBtn.onclick = () => createFile(input.value);
        } else if (type === 'folder') {
            title.textContent = 'Create New Folder';
            desc.textContent = 'Create a new subdirectory.';
            input.placeholder = 'e.g. plugins';
            confirmBtn.onclick = () => createFolder(input.value);
        } else if (type === 'wget') {
            title.textContent = 'Remote URL Upload';
            desc.textContent = 'Download a file directly from a URL using wget.';
            input.placeholder = 'https://example.com/file.zip';
            wgetExtra.classList.remove('hidden');
            confirmBtn.onclick = () => remoteDownload(input.value);
        }

        modal.classList.remove('hidden');
        setTimeout(() => content.classList.remove('scale-95'), 10);
    }

    function closeModal() {
        const modal = document.getElementById('manager-modal');
        const content = document.getElementById('modal-content');
        content.classList.add('scale-95');
        setTimeout(() => modal.classList.add('hidden'), 200);
    }

    async function createFile(name) {
        if (!name) return;
        const res = await axios.post(`/instance/<%= req.params.id %>/files/create/${encodeURIComponent(name)}?path=${encodeURIComponent(currentPath)}`, { content: '' });
        if (res.status === 200) window.location.reload();
    }

    async function createFolder(name) {
        if (!name) return;
        const res = await axios.post(`/instance/<%= req.params.id %>/folders/create/${encodeURIComponent(name)}?path=${encodeURIComponent(currentPath)}`);
        if (res.status === 200) window.location.reload();
    }

    async function remoteDownload(url) {
        if (!url) return;
        document.getElementById('modal-confirm').disabled = true;
        document.getElementById('modal-confirm').innerHTML = '<i class="fas fa-spinner animate-spin"></i> Downloading...';
        try {
            const res = await axios.post(`/instance/<%= req.params.id %>/files/wget`, { url, path: currentPath });
            window.location.reload();
        } catch (e) {
            alert('Download failed. Check the URL and try again.');
            document.getElementById('modal-confirm').disabled = false;
            document.getElementById('modal-confirm').textContent = 'Confirm';
        }
    }

    // Selection Logic
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.file-checkbox');
    const floatingBar = document.getElementById('floatingActions');
    const countDisplay = document.getElementById('selectedCount');

    function updateFloatingBar() {
        const checked = document.querySelectorAll('.file-checkbox:checked').length;
        countDisplay.textContent = checked;
        if (checked > 0) floatingBar.classList.add('active');
        else floatingBar.classList.remove('active');
    }

    selectAll.addEventListener('change', (e) => {
        checkboxes.forEach(cb => cb.checked = e.target.checked);
        updateFloatingBar();
    });

    checkboxes.forEach(cb => cb.addEventListener('change', updateFloatingBar));

    async function deleteSingle(name) {
        if (confirm(`Delete ${name}?`)) {
            await axios.delete(`/instance/<%= req.params.id %>/files/delete/${encodeURIComponent(name)}?path=${encodeURIComponent(currentPath)}`);
            window.location.reload();
        }
    }
</script>
<%- include('../components/footer') %>
